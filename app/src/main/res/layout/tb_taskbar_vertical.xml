<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sidebar_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:id="@+id/sidebar_container"
        android:layout_width="68dp"
        android:layout_height="600dp" 
        android:background="@drawable/tb_capsule_bg"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginEnd="6dp"
        android:layout_marginStart="6dp"
        android:visibility="gone">

        <ScrollView
            android:id="@+id/taskbar_scrollview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <!-- This container holds both the list and the add button with 0 gap -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="center_horizontal">

                <!-- The Dynamic App List -->
                <LinearLayout
                    android:id="@+id/taskbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal" />

                <!-- THE ADD BUTTON: Sits with 0 gap under the last icon -->
                <ImageView
                    android:id="@+id/add_app_button"
                    android:layout_width="@dimen/tb_icon_size"
                    android:layout_height="@dimen/tb_icon_size"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="0dp"
                    android:background="@drawable/tb_add_button_bg_inset"
                    android:stateListAnimator="@animator/tb_button_press"
                    android:src="@drawable/tb_add_button_icon" 
                    android:tint="#FFFFFF"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <View
        android:id="@+id/sidebar_handle"
        android:layout_width="8dp"
        android:layout_height="80dp"
        android:background="@drawable/tb_handle_bg" />

</LinearLayout>
